# ServerMG Platform Configuration
# Copy this file to .env and fill in your values

# ===========================================
# General
# ===========================================
NODE_ENV=production
PLATFORM_DOMAIN=example.com
PLATFORM_URL=https://panel.example.com

# ===========================================
# PostgreSQL (Main Database)
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=servermg
POSTGRES_USER=servermg
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===========================================
# Redis
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ===========================================
# MongoDB (for user databases)
# ===========================================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_MONGO_PASSWORD

# ===========================================
# MySQL (for user databases)
# ===========================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

# ===========================================
# JWT Auth
# ===========================================
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ===========================================
# GitHub OAuth
# ===========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://panel.example.com/api/auth/github/callback

# ===========================================
# API
# ===========================================
API_PORT=4000
API_PREFIX=api

# ===========================================
# Dashboard
# ===========================================
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ===========================================
# Agent
# ===========================================
AGENT_PORT=4001
AGENT_SECRET=CHANGE_ME_AGENT_SECRET

# ===========================================
# SSL / Let's Encrypt
# ===========================================
LETSENCRYPT_EMAIL=admin@example.com

# ===========================================
# Monitoring
# ===========================================
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

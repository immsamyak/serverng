{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@servermg/shared-types": [
                "packages/shared-types/src"
            ],
            "@servermg/auth": [
                "packages/auth/src"
            ],
            "@servermg/logger": [
                "packages/logger/src"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}